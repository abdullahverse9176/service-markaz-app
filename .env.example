# Service Markaz Mobile App — Environment Variables
# Copy this to .env and fill in real values

# Backend API
EXPO_PUBLIC_API_URL=https://www.servicemarkaz.com

# Google Maps (Android key from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Expo Project ID (from expo.dev after linking)
EXPO_PUBLIC_EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID
